# Azure AKS dev testbed config (gitignored). Sourced by all aks-dev scripts.
export SUBSCRIPTION_ID="59279868-f33f-4001-84ce-25270e191de8"
export LOCATION="eastus"
export RESOURCE_GROUP="lightdash-aks-dev"
export ACR_NAME="ldaksdevXXXXXX"        # globally-unique, ^[a-z0-9]+$
export AKS_NAME="lightdash-aks"
export K8S_NAMESPACE="lightdash"
export HELM_RELEASE="lightdash"
export HELM_CHART_PATH="$HOME/code/helm-charts/charts/lightdash"
# Workload identity for the backend -> Sandboxes ADC data plane
export UAMI_NAME="lightdash-sandbox-identity"
export SERVICE_ACCOUNT_NAME="lightdash"
# Container Apps Sandboxes: one sandbox group + disk image per feature.
# Group names must match ^[a-z][a-z0-9-]*$. The disk image UUID is assigned at
# registration and captured by up.sh at runtime (not set here).
export DATA_APP_SANDBOX_GROUP="lightdash-data-app"
export WRITEBACK_SANDBOX_GROUP="lightdash-writeback"
# ACR images that back the disk images (built by build-sandbox-image.sh)
export SANDBOX_IMAGE_DATA_APP="ldaksdevXXXXXX.azurecr.io/lightdash-sandbox:data-app"
export SANDBOX_IMAGE_WRITEBACK="ldaksdevXXXXXX.azurecr.io/lightdash-sandbox:writeback"
# Sandbox resource tier (XS/S/M/L) + ADC data-plane API version
export SANDBOX_RESOURCE_TIER="M"
export SANDBOX_API_VERSION="2026-02-01-preview"
# App image (deploy.sh overrides tag to the branch image built on ACR)
export IMAGE_REPO="lightdash/lightdash"
export IMAGE_TAG="latest"
# Public hostname / TLS
export SITE_HOST_MODE="sslip"
export SITE_HOST=""
export LETSENCRYPT_EMAIL="oliver@lightdash.com"
# Secrets from 1Password (item names; mirror /k8s-dev)
export EE_LICENSE_OP_ITEM="Development Lightdash EE license key"
export ANTHROPIC_OP_ITEM="(dev) ANTHROPIC_API_KEY"
export ACA_LOCATION="eastus2"
# (resolved by up.sh; do not set by hand)
