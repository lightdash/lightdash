# Lightdash API access
LIGHTDASH_PAT=your-personal-access-token
LIGHTDASH_PROJECT_UUID=your-project-uuid
LIGHTDASH_URL=http://localhost:3000

# e2b sandbox (https://e2b.dev/dashboard)
E2B_API_KEY=e2b_...

# Claude CLI inside the sandbox
ANTHROPIC_API_KEY=sk-ant-...

# Optional: CDN base URL for production builds
VITE_ASSET_BASE_URL=/
