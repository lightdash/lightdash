# Lightdash API access
LIGHTDASH_PAT=your-personal-access-token
LIGHTDASH_PROJECT_UUID=your-project-uuid
LIGHTDASH_URL=http://localhost:3000

# e2b sandbox (https://e2b.dev/dashboard)
E2B_API_KEY=e2b_...

# Optional: override the template name (defaults to lightdash-data-app)
# E2B_TEMPLATE_NAME=lukas-dev-template
# Optional: tag for this build (defaults to E2B's implicit `default` tag)
# E2B_TEMPLATE_TAG=v1.0.0
# Optional: comma-separated extra tags assigned to the same build
# E2B_TEMPLATE_EXTRA_TAGS=latest,stable

# Claude CLI inside the sandbox
ANTHROPIC_API_KEY=sk-ant-...

# Optional: CDN base URL for production builds
VITE_ASSET_BASE_URL=/
