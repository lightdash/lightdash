# Agent Harness Credentials
# Copy this file to credentials.env and fill in your values:
#   cp agent-harness/cloud/credentials.env.template agent-harness/cloud/credentials.env
#
# Then run sync-credentials.sh to upload to your server:
#   ./agent-harness/cloud/sync-credentials.sh <server-ip>
#
# IMPORTANT: credentials.env is gitignored - never commit your actual keys!

# Required: Anthropic auth token for Claude Code
# Get yours by running: claude setup-token
ANTHROPIC_AUTH_TOKEN=

# Optional: Tailscale auth key for private network access
# Generate at: https://login.tailscale.com/admin/settings/keys
# Recommended: Create an ephemeral, single-use key that expires in 1 hour
TAILSCALE_AUTH_KEY=
