{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "lib": ["ESNext", "DOM"],
        "incremental": true,
        "jsx": "react",
        "jsxFactory": "xmlBuilder",
        "declaration": false,
        "declarationMap": false,
        "outDir": "dist",
        "rootDir": "src",
        "composite": false,
        "tsBuildInfoFile": "dist/.tsbuildinfo",
        "importHelpers": true,
        "isolatedModules": true,
        "experimentalDecorators": true,
        "moduleResolution": "bundler",
        "paths": {
            "better-ajv-errors": [
                "../common/node_modules/better-ajv-errors/typings.d.ts"
            ],
            "@casl/ability/dist/types/*": [
                "./node_modules/@casl/ability/dist/types/*"
            ]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node", "vitest/globals", "passport", "express-session"]
    },
    "files": ["src/@types/express-session.d.ts", "src/@types/express.d.ts"],
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json"],
    "exclude": ["dist", "node_modules", "src/ee/services/McpService/mcp-chart-app"],
    "references": [
        {
            "path": "../common"
        },
        {
            "path": "../warehouses"
        }
    ]
}
