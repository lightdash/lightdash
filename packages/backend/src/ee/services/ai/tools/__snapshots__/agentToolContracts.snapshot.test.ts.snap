                                                },
                                                "fieldType": {
                                                  "$ref": "#/properties/queryConfig/properties/customMetrics/anyOf/0/items/anyOf/0/properties/filters/anyOf/0/items/properties/filter/anyOf/2/anyOf/0/properties/fieldType",
                                                },
                                                "operator": {
