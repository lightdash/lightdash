                                                "exclusiveMinimum": 0,
                                                "type": "integer",
                                              },
                                              {
                                                "type": "null",
                                              },
                                            ],
                                            "description": "Number of rows for PRECEDING/FOLLOWING (e.g., 6 for "6 PRECEDING")",
                                          },
                                          "type": {
                                            "enum": [
                                              "unbounded_preceding",
                                              "preceding",
                                              "current_row",
                                              "following",
                                              "unbounded_following",
                                            ],
                                            "type": "string",
                                          },
