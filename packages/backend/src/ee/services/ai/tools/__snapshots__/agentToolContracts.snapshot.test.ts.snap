    "name": "runContentQuery",
    "outputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": [
                "success",
                "error",
              ],
              "type": "string",
            },
          },
          "required": [
            "status",
          ],
          "type": "object",
        },
