                          "null",
                        ],
                      },
                    },
                    "required": [
                      "name",
                      "label",
                    ],
                    "type": "object",
                  },
                  "type": "array",
                },
                "searchQuery": {
                  "type": "string",
                },
                "topMatchingFields": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "chartUsage": {
                        "type": [
                          "number",
                          "null",
                        ],
                      },
                      "fieldType": {
                        "type": "string",
                      },
                      "label": {
                        "type": "string",
                      },
                      "name": {
                        "type": "string",
                      },
                      "searchRank": {
                        "type": [
                          "number",
                          "null",
                        ],
                      },
                      "tableName": {
                        "type": "string",
                      },
                      "verifiedChartUsage": {
                        "type": [
                          "number",
                          "null",
                        ],
                      },
                    },
                    "required": [
                      "name",
                      "label",
                      "tableName",
                      "fieldType",
                    ],
                    "type": "object",
                  },
                  "type": "array",
                },
              },
              "required": [
                "searchQuery",
              ],
              "type": "object",
            },
            "status": {
              "enum": [
                "success",
                "error",
              ],
              "type": "string",
            },
          },
          "required": [
            "status",
          ],
          "type": "object",
        },
        "result": {
          "type": "string",
        },
      },
      "required": [
        "result",
        "metadata",
      ],
      "type": "object",
    },
