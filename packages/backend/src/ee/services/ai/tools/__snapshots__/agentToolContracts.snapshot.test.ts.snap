    "name": "readContent",
    "outputSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "anyOf": [
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "error",
                  "type": "string",
                },
              },
              "required": [
                "status",
              ],
              "type": "object",
            },
            {
              "additionalProperties": false,
              "properties": {
                "href": {
                  "type": "string",
                },
                "name": {
                  "type": "string",
                },
                "slug": {
                  "type": "string",
