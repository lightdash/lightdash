{
    "$schema": "../../node_modules/oxlint/configuration_schema.json",
    "categories": {
        "correctness": "off",
        "nursery": "off",
        "pedantic": "off",
        "perf": "off",
        "restriction": "off",
        "style": "off",
        "suspicious": "off"
    },
    "options": {
        "typeAware": true
    },
    "ignorePatterns": [
        "src/ee/services/McpService/mcp-chart-app/**",
        "src/ee/sandboxes/**",
        "src/generated/**"
    ],
    "plugins": ["typescript"],
    "rules": {
        "@typescript-eslint/no-unsafe-member-access": "error",
        "@typescript-eslint/no-unsafe-assignment": "error",
        "@typescript-eslint/no-unsafe-call": "error"
    },
    "overrides": [
        {
            "files": [
                "src/*.ts",
                "src/analytics/**/*.ts",
                "src/clients/**/*.ts",
                "src/controllers/**/*.ts",
                "src/database/**/*.ts",
                "src/dbt/**/*.ts",
                "src/ee/**/*.ts",
                "src/models/**/*.ts",
                "src/services/**/*.ts",
                "src/utils/**/*.ts",
                "src/logging/**/*.ts",
                "src/scheduler/**/*.ts",
                "src/config/**/*.ts",
                "src/projectAdapters/**/*.ts",
                "src/prometheus/**/*.ts",
                "src/database/migrations/*.ts",
                "src/routers/*.ts"
            ],
            "rules": {
                "@typescript-eslint/no-unsafe-member-access": "off",
                "@typescript-eslint/no-unsafe-assignment": "off",
                "@typescript-eslint/no-unsafe-call": "off"
            }
        },
        {
            "files": ["**/*.mock.ts", "**/*.test.ts", "**/*.spec.ts"],
            "rules": {
                "@typescript-eslint/no-unsafe-member-access": "off",
                "@typescript-eslint/no-unsafe-assignment": "off",
                "@typescript-eslint/no-unsafe-call": "off"
            }
        }
    ]
}
