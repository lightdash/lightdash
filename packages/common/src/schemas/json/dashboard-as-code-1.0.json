{
    "$defs": {
        "AnyType": {
            "description": "This AnyType is an alias for any\nThe goal is to make it easier to identify any type in the codebase\nwithout having to eslint-disable all the time\nThese are only used on legacy `any` types, don't use it for new types.\nThis is added on a separate file to avoid circular dependencies."
        },
        "ContentAsCodeType.DASHBOARD": {
            "enum": [
                "dashboard"
            ],
            "type": "string"
        },
        "ContentVerificationInfo": {
            "properties": {
                "verifiedAt": {
                    "format": "date-time",
                    "type": "string"
                },
                "verifiedBy": {
                    "properties": {
                        "firstName": {
                            "type": "string"
                        },
                        "lastName": {
                            "type": "string"
                        },
                        "userUuid": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "lastName",
                        "firstName",
                        "userUuid"
                    ],
                    "type": "object"
                }
            },
            "required": [
                "verifiedAt",
                "verifiedBy"
            ],
            "type": "object"
        },
        "DashboardChartTileAsCode": {
            "allOf": [
                {
                    "$ref": "#/$defs/DashboardTileAsCodeBase"
                },
                {
                    "properties": {
                        "properties": {
                            "allOf": [
                                {
                                    "$ref": "#/$defs/Pick_DashboardChartTileProperties-at-properties.title-or-hideTitle-or-chartName_"
                                },
                                {
                                    "properties": {
                                        "chartSlug": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "chartSlug"
                                    ],
                                    "type": "object"
                                }
                            ]
                        },
                        "type": {
                            "$ref": "#/$defs/DashboardTileTypes.SAVED_CHART"
                        }
                    },
                    "required": [
                        "properties",
                        "type"
                    ],
                    "type": "object"
                }
            ]
        },
        "DashboardConfig": {
            "properties": {
                "dateZoomGranularities": {
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/DateGranularity"
                            },
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "type": "array"
                },
                "defaultDateZoomGranularity": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/DateGranularity"
                        },
                        {
                            "type": "string"
                        }
                    ]
                },
                "isAddFilterDisabled": {
                    "type": "boolean"
                },
                "isDateZoomDisabled": {
                    "type": "boolean"
                },
                "parameterOrder": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "pinnedParameters": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "required": [
                "isDateZoomDisabled"
            ],
            "type": "object"
        },
        "DashboardDataAppTileAsCode": {
            "allOf": [
                {
                    "$ref": "#/$defs/DashboardTileAsCodeBase"
                },
                {
                    "properties": {
                        "properties": {
                            "properties": {
                                "appDeletedAt": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },
                                "appUuid": {
                                    "type": "string"
                                },
                                "hideTitle": {
                                    "type": "boolean"
                                },
                                "title": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "appUuid",
                                "title"
                            ],
                            "type": "object"
                        },
                        "type": {
                            "$ref": "#/$defs/DashboardTileTypes.DATA_APP"
                        }
                    },
                    "required": [
                        "properties",
                        "type"
                    ],
                    "type": "object"
                }
            ]
        },
        "DashboardFieldTarget": {
            "properties": {
                "fallbackType": {
                    "$ref": "#/$defs/DimensionType"
                },
                "fieldId": {
                    "type": "string"
                },
                "isSqlColumn": {
                    "type": "boolean"
                },
                "tableName": {
                    "type": "string"
                }
            },
            "required": [
                "tableName",
                "fieldId"
            ],
            "type": "object"
        },
        "DashboardFilterRule": {
            "allOf": [
                {
                    "$ref": "#/$defs/FilterRule_FilterOperator.DashboardFieldTarget.AnyType.AnyType_"
                },
                {
                    "properties": {
                        "label": {
                            "type": "string"
                        },
                        "lockedTabUuids": {
                            "description": "Tab UUIDs where this filter is locked. When the active tab is in this\nlist, viewers see the filter but cannot change it, and URL / embed\nfilter overrides targeting the same field are ignored on that tab.\nEmpty or omitted means the filter is not locked anywhere.",
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        "singleValue": {
                            "type": "boolean"
                        },
                        "tileTargets": {
                            "$ref": "#/$defs/Record_string.DashboardTileTarget_"
                        }
                    },
                    "type": "object"
                }
            ]
        },
        "DashboardHeadingTileAsCode": {
            "allOf": [
                {
                    "$ref": "#/$defs/DashboardTileAsCodeBase"
                },
                {
                    "properties": {
                        "properties": {
                            "properties": {
                                "showDivider": {
                                    "type": "boolean"
                                },
                                "text": {
                                    "type": "string"
                                },
                                "title": {}
                            },
                            "required": [
                                "text"
                            ],
                            "type": "object"
                        },
                        "type": {
                            "$ref": "#/$defs/DashboardTileTypes.HEADING"
                        }
                    },
                    "required": [
                        "properties",
                        "type"
                    ],
                    "type": "object"
                }
            ]
        },
        "DashboardLoomTileAsCode": {
            "allOf": [
                {
                    "$ref": "#/$defs/DashboardTileAsCodeBase"
                },
                {
                    "properties": {
                        "properties": {
                            "properties": {
                                "hideTitle": {
                                    "type": "boolean"
                                },
                                "title": {
                                    "type": "string"
                                },
                                "url": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "url",
                                "title"
                            ],
                            "type": "object"
                        },
                        "type": {
                            "$ref": "#/$defs/DashboardTileTypes.LOOM"
                        }
                    },
                    "required": [
                        "properties",
                        "type"
                    ],
                    "type": "object"
                }
            ]
        },
        "DashboardMarkdownTileAsCode": {
            "allOf": [
                {
                    "$ref": "#/$defs/DashboardTileAsCodeBase"
                },
                {
                    "properties": {
                        "properties": {
                            "properties": {
                                "content": {
                                    "type": "string"
                                },
                                "hideFrame": {
                                    "type": "boolean"
                                },
                                "title": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "content",
                                "title"
                            ],
                            "type": "object"
                        },
                        "type": {
                            "$ref": "#/$defs/DashboardTileTypes.MARKDOWN"
                        }
                    },
                    "required": [
                        "properties",
                        "type"
                    ],
                    "type": "object"
                }
            ]
        },
        "DashboardParameters": {
            "$ref": "#/$defs/Record_string.DashboardParameterValue_"
        },
        "DashboardParameterValue": {
            "properties": {
                "parameterName": {
                    "type": "string"
                },
                "value": {
                    "$ref": "#/$defs/ParameterValue"
                }
            },
            "required": [
                "value",
                "parameterName"
            ],
            "type": "object"
        },
        "DashboardSqlChartTileAsCode": {
            "allOf": [
                {
                    "$ref": "#/$defs/DashboardTileAsCodeBase"
                },
                {
                    "properties": {
                        "properties": {
                            "allOf": [
                                {
                                    "$ref": "#/$defs/Pick_DashboardSqlChartTileProperties-at-properties.title-or-hideTitle-or-chartName_"
                                },
                                {
                                    "properties": {
                                        "chartSlug": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "chartSlug"
                                    ],
                                    "type": "object"
                                }
                            ]
                        },
                        "type": {
                            "$ref": "#/$defs/DashboardTileTypes.SQL_CHART"
                        }
                    },
                    "required": [
                        "properties",
                        "type"
                    ],
                    "type": "object"
                }
            ]
        },
        "DashboardTab": {
            "properties": {
                "hidden": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                },
                "order": {
                    "format": "double",
                    "type": "number"
                },
                "uuid": {
                    "type": "string"
                }
            },
            "required": [
                "hidden",
                "order",
                "name",
                "uuid"
            ],
            "type": "object"
        },
        "DashboardTileAsCode": {
            "anyOf": [
                {
                    "$ref": "#/$defs/DashboardChartTileAsCode"
                },
                {
                    "$ref": "#/$defs/DashboardSqlChartTileAsCode"
                },
                {
                    "$ref": "#/$defs/DashboardMarkdownTileAsCode"
                },
                {
                    "$ref": "#/$defs/DashboardLoomTileAsCode"
                },
                {
                    "$ref": "#/$defs/DashboardHeadingTileAsCode"
                },
                {
                    "$ref": "#/$defs/DashboardDataAppTileAsCode"
                }
            ]
        },
        "DashboardTileAsCodeBase": {
            "properties": {
                "h": {
                    "format": "double",
                    "type": "number"
                },
                "tabUuid": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "tileSlug": {
                    "type": "string"
                },
                "type": {
                    "$ref": "#/$defs/DashboardTileTypes"
                },
                "uuid": {
                    "type": "string"
                },
                "w": {
                    "format": "double",
                    "type": "number"
                },
                "x": {
                    "format": "double",
                    "type": "number"
                },
                "y": {
                    "format": "double",
                    "type": "number"
                }
            },
            "required": [
                "w",
                "h",
                "y",
                "x",
                "type"
            ],
            "type": "object"
        },
        "DashboardTileTarget": {
            "anyOf": [
                {
                    "$ref": "#/$defs/DashboardFieldTarget"
                },
                {
                    "enum": [
                        false
                    ],
                    "type": "boolean"
                }
            ]
        },
        "DashboardTileTypes": {
            "enum": [
                "saved_chart",
                "sql_chart",
                "markdown",
                "loom",
                "heading",
                "data_app"
            ],
            "type": "string"
        },
        "DashboardTileTypes.DATA_APP": {
            "enum": [
                "data_app"
            ],
            "type": "string"
        },
        "DashboardTileTypes.HEADING": {
            "enum": [
                "heading"
            ],
            "type": "string"
        },
        "DashboardTileTypes.LOOM": {
            "enum": [
                "loom"
            ],
            "type": "string"
        },
        "DashboardTileTypes.MARKDOWN": {
            "enum": [
                "markdown"
            ],
            "type": "string"
        },
        "DashboardTileTypes.SAVED_CHART": {
            "enum": [
                "saved_chart"
            ],
            "type": "string"
        },
        "DashboardTileTypes.SQL_CHART": {
            "enum": [
                "sql_chart"
            ],
            "type": "string"
        },
        "DateGranularity": {
            "enum": [
                "Second",
                "Minute",
                "Hour",
                "Day",
                "Week",
                "Month",
                "Quarter",
                "Year"
            ],
            "type": "string"
        },
        "DimensionType": {
            "enum": [
                "string",
                "number",
                "timestamp",
                "date",
                "boolean"
            ],
            "type": "string"
        },
        "FilterOperator": {
            "enum": [
                "isNull",
                "notNull",
                "equals",
                "notEquals",
                "startsWith",
                "endsWith",
                "include",
                "doesNotInclude",
                "lessThan",
                "lessThanOrEqual",
                "greaterThan",
                "greaterThanOrEqual",
                "inThePast",
                "notInThePast",
                "inTheNext",
                "inTheCurrent",
                "notInTheCurrent",
                "inBetween",
                "notInBetween",
                "inPeriodToDate"
            ],
            "type": "string"
        },
        "FilterRule_FilterOperator.DashboardFieldTarget.AnyType.AnyType_": {
            "additionalProperties": true,
            "properties": {
                "caseSensitive": {
                    "description": "Overrides the field/explore case-sensitivity for this rule only.\nUsed by internal features like autocomplete search that must always\nmatch case-insensitively regardless of the field's configured setting.",
                    "type": "boolean"
                },
                "disabled": {
                    "description": "Whether this filter is disabled",
                    "type": "boolean"
                },
                "id": {
                    "description": "Unique identifier for the filter",
                    "type": "string"
                },
                "operator": {
                    "$ref": "#/$defs/FilterOperator",
                    "description": "Filter operator"
                },
                "required": {
                    "description": "Whether this filter is required",
                    "type": "boolean"
                },
                "settings": {
                    "$ref": "#/$defs/AnyType",
                    "description": "Additional settings for date/time filters"
                },
                "target": {
                    "$ref": "#/$defs/DashboardFieldTarget",
                    "description": "Target field for the filter"
                },
                "values": {
                    "description": "Values to filter by",
                    "items": {
                        "$ref": "#/$defs/AnyType"
                    },
                    "type": "array"
                }
            },
            "required": [
                "operator",
                "id",
                "target"
            ],
            "type": "object"
        },
        "Omit_DashboardFilterRule.id_": {
            "$ref": "#/$defs/Pick_DashboardFilterRule.Exclude_keyofDashboardFilterRule.id__",
            "description": "Construct a type with the properties of T except for those in type K."
        },
        "ParameterValue": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "format": "double",
                    "type": "number"
                },
                {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                {
                    "items": {
                        "format": "double",
                        "type": "number"
                    },
                    "type": "array"
                }
            ]
        },
        "Pick_DashboardChartTileProperties-at-properties.title-or-hideTitle-or-chartName_": {
            "description": "From T, pick a set of properties whose keys are in the union K",
            "properties": {
                "chartName": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "hideTitle": {
                    "type": "boolean"
                },
                "title": {
                    "type": "string"
                }
            },
            "type": "object"
        },
        "Pick_DashboardFilterRule.Exclude_keyofDashboardFilterRule.id__": {
            "description": "From T, pick a set of properties whose keys are in the union K",
            "properties": {
                "caseSensitive": {
                    "description": "Overrides the field/explore case-sensitivity for this rule only.\nUsed by internal features like autocomplete search that must always\nmatch case-insensitively regardless of the field's configured setting.",
                    "type": "boolean"
                },
                "disabled": {
                    "description": "Whether this filter is disabled",
                    "type": "boolean"
                },
                "label": {
                    "type": "string"
                },
                "lockedTabUuids": {
                    "description": "Tab UUIDs where this filter is locked. When the active tab is in this\nlist, viewers see the filter but cannot change it, and URL / embed\nfilter overrides targeting the same field are ignored on that tab.\nEmpty or omitted means the filter is not locked anywhere.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "operator": {
                    "$ref": "#/$defs/FilterOperator",
                    "description": "Filter operator"
                },
                "required": {
                    "description": "Whether this filter is required",
                    "type": "boolean"
                },
                "settings": {
                    "description": "Additional settings for date/time filters"
                },
                "singleValue": {
                    "type": "boolean"
                },
                "target": {
                    "$ref": "#/$defs/DashboardFieldTarget",
                    "description": "Target field for the filter"
                },
                "tileTargets": {
                    "$ref": "#/$defs/Record_string.DashboardTileTarget_"
                },
                "values": {
                    "description": "Values to filter by",
                    "items": {},
                    "type": "array"
                }
            },
            "required": [
                "target",
                "operator"
            ],
            "type": "object"
        },
        "Pick_DashboardSqlChartTileProperties-at-properties.title-or-hideTitle-or-chartName_": {
            "description": "From T, pick a set of properties whose keys are in the union K",
            "properties": {
                "chartName": {
                    "type": "string"
                },
                "hideTitle": {
                    "type": "boolean"
                },
                "title": {
                    "type": "string"
                }
            },
            "required": [
                "chartName"
            ],
            "type": "object"
        },
        "Record_string.DashboardParameterValue_": {
            "additionalProperties": {
                "$ref": "#/$defs/DashboardParameterValue"
            },
            "description": "Construct a type with a set of properties K of type T",
            "properties": {},
            "type": "object"
        },
        "Record_string.DashboardTileTarget_": {
            "additionalProperties": {
                "$ref": "#/$defs/DashboardTileTarget"
            },
            "description": "Construct a type with a set of properties K of type T",
            "properties": {},
            "type": "object"
        }
    },
    "$id": "https://schemas.lightdash.com/lightdash/dashboard-as-code.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "description": "From T, pick a set of properties whose keys are in the union K",
    "properties": {
        "config": {
            "$ref": "#/$defs/DashboardConfig"
        },
        "contentType": {
            "$ref": "#/$defs/ContentAsCodeType.DASHBOARD"
        },
        "description": {
            "type": "string"
        },
        "downloadedAt": {
            "format": "date-time",
            "type": "string"
        },
        "filters": {
            "properties": {
                "dimensions": {
                    "items": {
                        "$ref": "#/$defs/Omit_DashboardFilterRule.id_"
                    },
                    "type": "array"
                },
                "metrics": {
                    "items": {
                        "$ref": "#/$defs/DashboardFilterRule"
                    },
                    "type": "array"
                },
                "tableCalculations": {
                    "items": {
                        "$ref": "#/$defs/DashboardFilterRule"
                    },
                    "type": "array"
                }
            },
            "type": "object"
        },
        "name": {
            "type": "string"
        },
        "parameters": {
            "$ref": "#/$defs/DashboardParameters"
        },
        "slug": {
            "type": "string"
        },
        "spaceSlug": {
            "type": "string"
        },
        "tabs": {
            "items": {
                "$ref": "#/$defs/DashboardTab"
            },
            "type": "array"
        },
        "tiles": {
            "items": {
                "$ref": "#/$defs/DashboardTileAsCode"
            },
            "type": "array"
        },
        "updatedAt": {
            "description": "Not modifiable by user, but useful to know if it has been updated. Defaults to now if omitted.",
            "format": "date-time",
            "type": "string"
        },
        "verification": {
            "anyOf": [
                {
                    "allOf": [
                        {
                            "$ref": "#/$defs/ContentVerificationInfo"
                        }
                    ],
                    "description": "Detailed verification info (who/when). Read-only; ignored on upload."
                },
                {
                    "type": "null"
                }
            ]
        },
        "verified": {
            "description": "Declarative verification state.\n`true` verifies the dashboard on upload, `false` unverifies it, `undefined` leaves the\ncurrent state untouched. Download sets this to `true` when the dashboard is verified.",
            "type": "boolean"
        },
        "version": {
            "const": 1,
            "format": "double",
            "type": "number"
        }
    },
    "required": [
        "name",
        "slug",
        "tabs",
        "spaceSlug",
        "version",
        "tiles"
    ],
    "title": "Lightdash Dashboard as Code",
    "type": "object"
}
