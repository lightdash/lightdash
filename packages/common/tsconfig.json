{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "es2020",
        "lib": ["ESNext"],
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist/types",
        "rootDir": "src",
        "composite": true,
        "tsBuildInfoFile": "dist/types/.tsbuildinfo",
        "importHelpers": true,
        "moduleResolution": "bundler",
        "paths": {
            "better-ajv-errors": ["./node_modules/better-ajv-errors/typings.d.ts"]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node", "vitest/globals"]
    },
    "include": ["src/**/*.ts", "src/**/*.json"]
}
