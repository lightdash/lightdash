{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": ["ESNext"],
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "composite": true,
        "tsBuildInfoFile": "dist/.tsgo.tsbuildinfo",
        "importHelpers": true,
        "noUncheckedIndexedAccess": false,
        "moduleResolution": "bundler",
        "paths": {
            "better-ajv-errors": ["./node_modules/better-ajv-errors/typings.d.ts"]
        },
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node", "vitest/globals"]
    },
    "include": ["src/**/*.ts", "src/**/*.json"],
    "references": [
        {
            "path": "../common"
        },
        {
            "path": "../warehouses"
        }
    ]
}
