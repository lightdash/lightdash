{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "lib": ["ESNext"],
        "declaration": true,
        "declarationMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "composite": true,
        "tsBuildInfoFile": "dist/.tsbuildinfo",
        "importHelpers": true,
        "noUncheckedIndexedAccess": false,
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node10",
        "jsx": "react-jsx",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node", "vitest/globals"]
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json"],
    "references": [
        {
            "path": "../common"
        },
        {
            "path": "../warehouses"
        }
    ]
}
