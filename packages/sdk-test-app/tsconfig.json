{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "composite": false,
        "target": "ESNext",
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "paths": {
            "@lightdash/common": ["../common/src/index.ts"],
            "@lightdash/common/*": ["../common/src/*"],
            "@lightdash/sdk": ["../frontend/sdk/index.tsx"],
            "@lightdash/sdk/sdk.css": ["../frontend/sdk/dist/sdk.css"],
            "better-ajv-errors": [
                "../common/node_modules/better-ajv-errors/typings.d.ts"
            ]
        },
        "types": [
            "vite/client",
            "./vite-env.d.ts"
        ]
    },
    "include": ["src", "../frontend/src/types/**/*.d.ts"]
}
