{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "target": "ES2020",
        "lib": ["ES2020", "dom"],
        "types": [
            "node"
        ],
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node10",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": ["**/*.ts"]
}
