{
    "extends": "./../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "dom"],
        "types": ["node"],
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": ["playwright.config.ts", "playwright/**/*.ts"]
}
