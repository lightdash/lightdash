{
    "name": "e2e",
    "version": "0.2744.1",
    "private": true,
    "license": "MIT",
    "main": "index.js",
    "scripts": {
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:debug": "playwright test --debug",
        "test:report": "playwright show-report",
        "linter": "eslint -c .eslintrc.js --ignore-path ./../../.gitignore",
        "formatter": "oxfmt",
        "lint": "pnpm run linter ./playwright",
        "fix-lint": "pnpm run linter ./playwright --fix",
        "format": "oxfmt ./playwright --check",
        "fix-format": "oxfmt ./playwright"
    },
    "dependencies": {
        "@lightdash/common": "workspace:*",
        "@playwright/test": "1.52.0",
        "dayjs": "1.11.10",
        "js-yaml": "4.1.1"
    },
    "devDependencies": {
        "typescript": "6.0.0-beta"
    }
}
