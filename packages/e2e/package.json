{
    "name": "e2e",
    "version": "0.3426.0",
    "private": true,
    "license": "MIT",
    "main": "index.js",
    "scripts": {
        "playwright:open": "TZ=${TZ:-UTC} playwright test --ui",
        "playwright:run": "TZ=${TZ:-UTC} playwright test",
        "playwright:list": "TZ=${TZ:-UTC} playwright test --list",
        "playwright:report": "playwright show-report",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "linter": "eslint -c .eslintrc.js --ignore-path ./../../.gitignore",
        "formatter": "oxfmt --ignore-path ./../../.gitignore",
        "lint": "pnpm run linter ./playwright ./playwright.config.ts",
        "fix-lint": "pnpm run linter ./playwright ./playwright.config.ts --fix",
        "format": "pnpm run formatter ./playwright ./playwright.config.ts ./tsconfig.json --check",
        "fix-format": "pnpm run formatter ./playwright ./playwright.config.ts ./tsconfig.json"
    },
    "dependencies": {
        "@lightdash/common": "workspace:*"
    },
    "devDependencies": {
        "@playwright/test": "1.56.1",
        "typescript": "npm:@typescript/typescript6@6.0.1",
        "typescript-7": "npm:typescript@7.0.1-rc"
    }
}
