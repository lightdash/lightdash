{
  "name": "@lightdash/formula",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:grammar": "peggy --format es -o src/grammar/parser.js src/grammar/formula.pegjs",
    "build:ts": "tsc --build",
    "build:ts:fast": "tsgo --build tsconfig.fast.json",
    "build": "peggy --format es -o src/grammar/parser.js src/grammar/formula.pegjs && tsc --build",
    "build:fast": "peggy --format es -o src/grammar/parser.js src/grammar/formula.pegjs && tsgo --build tsconfig.fast.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "typecheck:fast": "tsgo --project tsconfig.fast.json --noEmit",
    "format": "oxfmt ./src --check",
    "fix-format": "oxfmt ./src",
    "formatter": "oxfmt",
    "lint": "pnpm run linter ./src",
    "fix-lint": "pnpm run linter ./src --fix",
    "linter": "oxlint -c .oxlintrc.json --ignore-path ./../../.gitignore",
    "test": "vitest run"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "peggy": "4.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
