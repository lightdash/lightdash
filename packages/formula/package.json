{
  "name": "@lightdash/formula",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build:grammar": "peggy --format es -o src/grammar/parser.js src/grammar/formula.pegjs",
    "build:ts": "tsc6 --build",
    "build:ts:fast": "tsc --build tsconfig.fast.json",
    "build": "pnpm run build:grammar && pnpm run build:ts",
    "build:fast": "pnpm run build:grammar && pnpm run build:ts:fast",
    "typecheck": "tsc6 --project tsconfig.json --noEmit",
    "typecheck:fast": "tsc --project tsconfig.fast.json --noEmit",
    "format": "oxfmt ./src --check",
    "fix-format": "oxfmt ./src",
    "formatter": "oxfmt",
    "lint": "pnpm run linter ./src",
    "fix-lint": "pnpm run linter ./src --fix",
    "linter": "oxlint -c .oxlintrc.json --ignore-path ./../../.gitignore",
    "test": "vitest run"
  },
  "devDependencies": {
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.1",
    "peggy": "4.2.0",
    "typescript": "npm:@typescript/typescript6@6.0.1",
    "typescript-7": "npm:typescript@7.0.1-rc",
    "vitest": "4.1.6"
  }
}
