{
    "name": "lightdash",
    "version": "0.2936.0",
    "main": "index.js",
    "license": "MIT",
    "private": true,
    "workspaces": [
        "packages/*",
        "packages/frontend/sdk"
    ],
    "pnpm": {
        "onlyBuiltDependencies": [
            "@sentry-internal/node-cpu-profiler",
            "@sentry/cli",
            "@swc/core",
            "bcrypt",
            "canvas",
            "core-js",
            "core-js-pure",
            "cpu-features",
            "cypress",
            "duckdb",
            "esbuild",
            "lz4",
            "msgpackr-extract",
            "protobufjs",
            "sharp",
            "ssh2"
        ],
        "overrides": {
            "react-is": "19.2.0",
            "@types/react": "19.2.2",
            "@types/react-dom": "19.2.2",
            "linkifyjs": "4.3.2",
            "axios": "1.15.2",
            "form-data@2.5.3": "2.5.5",
            "form-data@3.0.1": "3.0.4",
            "form-data@4.0.0": "4.0.4",
            "form-data@4.0.2": "4.0.4",
            "validator": "13.15.23",
            "node-forge": "1.4.0",
            "glob@>=10.2.0 <10.5.0": "10.5.0",
            "jws": "4.0.1",
            "qs": "6.14.1",
            "hono": "4.12.4",
            "tar": "7.5.11",
            "eslint": "8.57.1",
            "canvas": "3.2.1",
            "express-rate-limit": "8.3.0",
            "@hapi/content": "6.0.1",
            "undici": "6.24.1",
            "handlebars": "4.7.9",
            "basic-ftp": "5.2.1",
            "vite@>=7.0.0 <7.3.2": "7.3.2",
            "systeminformation": "5.31.0",
            "path-to-regexp@0.1.12": "0.1.13",
            "ajv@<6.14.0": "6.15.0",
            "ajv@>=8.0.0 <8.18.0": "8.18.0"
        }
    },
    "dependencies": {
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@spotlightjs/spotlight": "4.10.0",
        "@types/jest": "29.5.5",
        "@types/node": "22.13.1",
        "@types/pegjs": "0.10.3",
        "@typescript-eslint/eslint-plugin": "7.18.0",
        "@typescript-eslint/parser": "7.18.0",
        "confusing-browser-globals": "1.0.11",
        "dotenv": "16.0.3",
        "dotenv-cli": "6.0.0",
        "eslint": "8.57.1",
        "eslint-config-airbnb": "19.0.4",
        "eslint-config-airbnb-base": "15.0.0",
        "eslint-config-airbnb-typescript": "18.0.0",
        "eslint-config-prettier": "8.5.0",
        "eslint-plugin-import": "2.26.0",
        "eslint-plugin-jest": "27.4.2",
        "eslint-plugin-json": "3.1.0",
        "eslint-plugin-jsx-a11y": "6.6.1",
        "eslint-plugin-perfectionist": "5.6.0",
        "eslint-plugin-react-hooks": "4.6.0",
        "eslint-plugin-testing-library": "5.6.3",
        "husky": "9.1.7",
        "jest": "29.7.0",
        "jest-watch-typeahead": "2.2.2",
        "lint-staged": "12.1.2",
        "oxfmt": "0.35.0",
        "pm2": "6.0.14",
        "ts-jest": "29.1.1",
        "tsx": "4.19.4",
        "turbo": "2.6.2",
        "typescript": "6.0.0-beta"
    },
    "scripts": {
        "formula:build": "pnpm -F formula build",
        "formula:test": "pnpm -F formula test",
        "formula:test:fast": "pnpm -F formula-tests test:fast",
        "formula:test:tier1": "pnpm -F formula-tests test:tier1",
        "formula:test:tier2": "pnpm -F formula-tests test:tier2",
        "formula:test:all": "pnpm -F formula-tests test:all",
        "formula:test:warehouse": "pnpm -F formula-tests exec tsx run.ts --tier all --warehouse",
        "common-dev": "pnpm -F common dev",
        "common-build": "pnpm -F common build",
        "common-lint": "pnpm -F common lint",
        "common-format": "pnpm -F common format",
        "common-fix-lint": "pnpm -F common fix-lint",
        "common-fix-format": "pnpm -F common fix-format",
        "common-test": "pnpm -F common test",
        "common-typecheck": "pnpm -F common typecheck",
        "backend-dev": "pnpm -F backend dev",
        "backend-build": "pnpm -F backend build",
        "backend-start": "pnpm -F backend start",
        "backend-nats-worker": "pnpm -F backend nats-worker",
        "backend-nats-worker-dev": "pnpm -F backend nats-worker-dev",
        "backend-lint": "pnpm -F backend lint",
        "backend-format": "pnpm -F backend format",
        "backend-fix-lint": "pnpm -F backend fix-lint",
        "backend-fix-format": "pnpm -F backend fix-format",
        "backend-test": "pnpm -F backend test",
        "backend-test-metric-query-builder-snapshots:update": "pnpm -F backend test:snapshots:update",
        "backend-test-integration": "pnpm -F backend test:integration",
        "backend-test-sequential": "pnpm -F backend test-sequential",
        "backend-typecheck": "pnpm -F backend typecheck",
        "frontend-dev": "pnpm -F frontend dev",
        "frontend-build": "pnpm -F frontend build",
        "frontend-build-sdk": "pnpm -F frontend build-sdk",
        "frontend-lint": "pnpm -F frontend lint",
        "frontend-format": "pnpm -F frontend format",
        "frontend-fix-lint": "pnpm -F frontend fix-lint",
        "frontend-fix-format": "pnpm -F frontend fix-format",
        "frontend-test": "pnpm -F frontend test",
        "frontend-typecheck": "pnpm -F frontend typecheck",
        "sdk-typecheck": "pnpm -F frontend typecheck-sdk",
        "sdk-build": "pnpm common-build && pnpm frontend-build-sdk",
        "e2e-open": "pnpm -F e2e cypress:open",
        "e2e-open-native": "pnpm -F e2e cypress:open:native",
        "e2e-run": "pnpm -F e2e cypress:run",
        "e2e-lint": "pnpm -F e2e lint",
        "e2e-format": "pnpm -F e2e format",
        "e2e-fix-lint": "pnpm -F e2e fix-lint",
        "e2e-fix-format": "pnpm -F e2e fix-format",
        "api-test": "pnpm -F api-tests test:api",
        "api-typecheck": "pnpm -F api-tests typecheck",
        "cli-test": "pnpm -F cli test",
        "cli-lint": "pnpm -F cli lint",
        "cli-format": "pnpm -F cli format",
        "cli-fix-lint": "pnpm -F cli fix-lint",
        "cli-fix-format": "pnpm -F cli fix-format",
        "cli-build": "pnpm -F cli build",
        "cli-typecheck": "pnpm -F cli typecheck",
        "warehouses-dev": "pnpm -F warehouses dev",
        "warehouses-lint": "pnpm -F warehouses lint",
        "warehouses-format": "pnpm -F warehouses format",
        "warehouses-fix-lint": "pnpm -F warehouses fix-lint",
        "warehouses-fix-format": "pnpm -F warehouses fix-format",
        "warehouses-test": "pnpm -F warehouses test",
        "warehouses-build": "pnpm -F warehouses build",
        "warehouses-typecheck": "pnpm -F warehouses typecheck",
        "typecheck": "turbo run typecheck --filter=@lightdash/common --filter=@lightdash/warehouses --filter=@lightdash/cli --filter=backend --filter=@lightdash/frontend --filter=api-tests",
        "lint": "turbo run lint --filter=@lightdash/common --filter=@lightdash/warehouses --filter=backend --filter=@lightdash/frontend --filter=e2e --filter=@lightdash/cli --filter=api-tests",
        "format": "turbo run format --filter=@lightdash/common --filter=@lightdash/warehouses --filter=backend --filter=@lightdash/frontend --filter=e2e --filter=@lightdash/cli --filter=api-tests",
        "fix-lint": "turbo run fix-lint --filter=@lightdash/common --filter=@lightdash/warehouses --filter=backend --filter=@lightdash/frontend --filter=e2e --filter=@lightdash/cli --filter=api-tests",
        "fix-format": "turbo run fix-format --filter=@lightdash/common --filter=@lightdash/warehouses --filter=backend --filter=@lightdash/frontend --filter=e2e --filter=@lightdash/cli --filter=api-tests",
        "test": "turbo run test --filter=@lightdash/common --filter=@lightdash/warehouses --filter=backend --filter=@lightdash/frontend --filter=e2e --filter=@lightdash/cli --filter=api-tests",
        "dev": "pnpm -r --stream --parallel -F common -F warehouses -F backend -F frontend run dev",
        "build": "turbo run build --filter=@lightdash/common --filter=@lightdash/warehouses --filter=backend --filter=@lightdash/frontend",
        "build-published-packages": "pnpm -r --stream --sequential -F common -F warehouses -F query-sdk -F cli -F formula build && pnpm frontend-build-sdk",
        "release-packages": "pnpm -r --stream --sequential -F common -F warehouses -F query-sdk -F cli -F frontend release",
        "start": "pnpm run backend-start",
        "prepare": "husky || true",
        "load:env": "dotenv -c -e .env.development.local",
        "generate-api": "pnpm run common-build && pnpm -F backend generate-api && pnpm -F backend formatter --write ./src/generated",
        "generate-api-dev": "pnpm run common-build && pnpm -F backend generate-api-dev",
        "generate:chart-as-code-schema": "pnpm -F common generate:chart-as-code-schema",
        "check:chart-as-code-schema": "pnpm -F common check:chart-as-code-schema",
        "clean-node-modules": "./scripts/clean-node-modules.sh && pnpm install",
        "clean-build-cache": "./scripts/clean-build-cache.sh",
        "clean": "pnpm clean-build-cache && pnpm clean-node-modules",
        "clean-and-build": "pnpm clean && pnpm build",
        "http": "pnpx httpyac",
        "pm2:start": "pm2 start ecosystem.config.js",
        "pm2:stop": "pm2 stop all",
        "pm2:restart": "pm2 restart all",
        "pm2:delete": "pm2 delete all",
        "pm2:status": "pm2 status",
        "pm2:monit": "pm2 monit",
        "pm2:logs": "pm2 logs --lines 50",
        "pm2:logs:api": "pm2 logs lightdash-api --lines 50",
        "pm2:logs:scheduler": "pm2 logs lightdash-scheduler --lines 50",
        "pm2:logs:frontend": "pm2 logs lightdash-frontend --lines 50",
        "pm2:restart:api": "pm2 restart lightdash-api",
        "pm2:restart:scheduler": "pm2 restart lightdash-scheduler",
        "pm2:restart:frontend": "pm2 restart lightdash-frontend",
        "pm2:logs:spotlight": "pm2 logs lightdash-spotlight --lines 50",
        "pm2:restart:spotlight": "pm2 restart lightdash-spotlight",
        "spotlight": "pnpm dlx @spotlightjs/spotlight@latest",
        "dev:pm2": "pm2 start ecosystem.config.js && pm2 logs --lines 50"
    },
    "lint-staged": {
        "packages/frontend/src/**/*.(ts|tsx|json|css)": [
            "pnpm -F frontend run linter --fix",
            "pnpm -F frontend run formatter"
        ],
        "packages/backend/src/**/*.(ts|tsx|json)": [
            "pnpm -F backend run linter --fix",
            "pnpm -F backend run formatter"
        ],
        "packages/common/src/**/*.(ts|tsx|json)": [
            "pnpm -F common run linter --fix",
            "pnpm -F common run formatter"
        ],
        "packages/e2e/cypress/**/*.(ts|json)": [
            "pnpm -F e2e run linter --fix",
            "pnpm -F e2e run formatter"
        ],
        "packages/cli/src/**/*.(ts|tsx|json)": [
            "pnpm -F cli run linter --fix",
            "pnpm -F cli run formatter"
        ],
        "packages/warehouses/src/**/*.(ts|tsx|json)": [
            "pnpm -F warehouses run linter --fix",
            "pnpm -F warehouses run formatter"
        ],
        "packages/api-tests/**/*.(ts|json)": [
            "pnpm -F api-tests run linter --fix",
            "pnpm -F api-tests run formatter"
        ],
        "packages/formula/src/**/*.(ts|json)": [
            "pnpm -F formula run linter --fix",
            "pnpm -F formula run formatter"
        ]
    },
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
