{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "cache": true
    },
    "build:fast": {
      "dependsOn": ["^build:fast"],
      "outputs": ["dist/**", "build/**"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "format": {
      "cache": true
    },
    "fix-lint": {
      "cache": false
    },
    "fix-format": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    }
  }
}
